# /etc/fabt/pgaudit-alert.env — EnvironmentFile for
# fabt-pgaudit-alert.service. Copy this example to /etc/fabt/ and fill
# in real values; do NOT commit a populated copy to git.
#
# Permissions on the real file MUST be 640 (root:fabt) — the file
# contains a Slack/PagerDuty webhook URL that can be used to post
# arbitrary messages to the team's channel.

# Slack incoming-webhook URL from 1Password entry
# `fabt-panic-alert-webhook`. Required.
FABT_PANIC_ALERT_WEBHOOK=

# docker container name (from `docker ps --format '{{.Names}}'`).
# Typically `postgres` or `fabt-postgres` depending on docker-compose
# project name. Required if the default `postgres` name isn't right.
FABT_POSTGRES_CONTAINER=postgres

# Optional: seconds between duplicate alerts for the same table.
# Default 300 (5 minutes) prevents a rapid-fire operator test that
# flips NO FORCE/FORCE on/off repeatedly from flooding the webhook
# channel. Set lower for post-incident sensitivity tuning.
# FABT_ALERT_COOLDOWN_SECS=300

# Optional: initial --since window for the docker logs tail. Keep
# short to avoid flooding the channel after a systemd restart.
# FABT_ALERT_TAIL_SINCE=1m

# Optional: heartbeat file path. The operator's weekly health-check
# cron reads this file's mtime to verify the tail service is alive.
# FABT_HEARTBEAT_FILE=/var/lib/fabt/pgaudit-alert-tail.heartbeat
