# Frontend build-time configuration. Copy to `.env` (or `.env.production`)
# and set values for local dev / prod overrides. All Vite env vars MUST be
# prefixed with VITE_ to be exposed to client code.
#
# These are NOT secrets — values land in the JS bundle as string literals.
# For real secrets, use the backend env, not this file.

# Platform-operator UI rollback gate (F11 v0.54).
# Default 'true'. Set to 'false' to rebuild the frontend WITHOUT the
# /platform/* SPA chunk — useful for emergency rollback (the dynamic
# import is dead-code-eliminated, dist/assets/platform-*.js is absent).
# Backend GET /me + POST /logout endpoints are NOT affected by this flag.
VITE_PLATFORM_UI_ENABLED=true
