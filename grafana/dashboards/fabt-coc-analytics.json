{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "System Utilization Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "avg(fabt_bed_utilization_ratio)",
          "legendFormat": "Utilization",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1.2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green", "value": 0.65 },
              { "color": "red", "value": 1.05 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Zero-Result Search Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "rate(fabt_search_zero_results_total[1h])",
          "legendFormat": "Zero-result searches/hour",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "title": "Reservation Conversion Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(fabt_reservation_confirmed_total[1h])) / sum(rate(fabt_reservation_created_total[1h]))",
          "legendFormat": "Conversion %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Bed Capacity Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(fabt_beds_total)",
          "legendFormat": "Total Beds",
          "refId": "A"
        },
        {
          "expr": "sum(fabt_beds_occupied)",
          "legendFormat": "Occupied",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Demand vs Capacity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(fabt_bed_search_total[1h])",
          "legendFormat": "Search Volume",
          "refId": "A"
        },
        {
          "expr": "sum(fabt_beds_available)",
          "legendFormat": "Available Beds",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Stale Shelter Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "fabt_stale_shelter_count",
          "legendFormat": "Stale Shelters",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Batch Job Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "rate(spring_batch_job_seconds_count{status=\"COMPLETED\"}[1h])",
          "legendFormat": "{{name}} success",
          "refId": "A"
        },
        {
          "expr": "rate(spring_batch_job_seconds_count{status=\"FAILED\"}[1h])",
          "legendFormat": "{{name}} failed",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },
    {
      "title": "Batch Job Duration Trends",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "rate(spring_batch_job_seconds_sum[5m]) / rate(spring_batch_job_seconds_count[5m])",
          "legendFormat": "{{name}} avg duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["fabt", "analytics"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FABT — CoC Analytics",
  "uid": "fabt-coc-analytics",
  "version": 1
}
