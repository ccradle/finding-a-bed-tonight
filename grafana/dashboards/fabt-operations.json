{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Bed Search Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(fabt_bed_search_count_total[1m])",
          "legendFormat": "{{populationType}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Bed Search Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(fabt_bed_search_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Availability Updates",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(fabt_availability_update_count_total[1m])",
          "legendFormat": "{{shelterId}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reservation Lifecycle",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(fabt_reservation_count_total[1m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Stale Shelter Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "fabt_shelter_stale_count",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "title": "DV Canary Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "fabt_dv_canary_pass",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "PASS", "color": "green" }, "0": { "text": "FAIL", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "Surge Active",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "fabt_surge_active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ACTIVE", "color": "orange" }, "0": { "text": "INACTIVE", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "Webhook Delivery Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(fabt_webhook_delivery_count_total{status=\"success\"}[1m])",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "expr": "rate(fabt_webhook_delivery_count_total{status=\"failure\"}[1m])",
          "legendFormat": "failure",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state",
          "legendFormat": "{{name}} - {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Temperature/Surge Gap",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "fabt_temperature_surge_gap",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "GAP DETECTED", "color": "red" } } }
          ]
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["fabt", "operations"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FABT Operations",
  "uid": "fabt-operations",
  "version": 1
}
