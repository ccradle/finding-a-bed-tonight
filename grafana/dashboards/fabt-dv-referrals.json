{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Referral Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(fabt_dv_referral_total{status=\"requested\"}[5m])",
          "legendFormat": "Requests/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "title": "Acceptance Rate (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "fabt_dv_referral_total{status=\"accepted\"} / fabt_dv_referral_total{status=\"requested\"} * 100",
          "legendFormat": "Acceptance %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 75 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Avg Response Time",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "rate(fabt_dv_referral_response_seconds_sum[1h]) / rate(fabt_dv_referral_response_seconds_count[1h]) / 60",
          "legendFormat": "Minutes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "min",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 120 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Rejection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(fabt_dv_referral_total{status=\"rejected\"}[5m])",
          "legendFormat": "Rejections/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "title": "Expired Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "rate(fabt_dv_referral_total{status=\"expired\"}[5m])",
          "legendFormat": "Expirations/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "description": "High expiry rate may indicate shelters not responding to referrals"
    },
    {
      "title": "Referral Totals",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "fabt_dv_referral_total",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "accepted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "rejected" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "expired" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["fabt", "dv", "referrals"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "FABT DV Referrals",
  "uid": "fabt-dv-referrals",
  "version": 1
}
