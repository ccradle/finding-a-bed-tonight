// ============================================================================
// Finding A Bed Tonight (FABT) — Database Schema
// Source: live PostgreSQL @ Flyway HWM V98 (dv-policy-tenant-flag +
//         platform-observability-split)
// Last synced: 2026-05-03 (regenerated via pg_dump + sql2dbml + curated
//         enum/Project preservation per `feedback_update_docs_with_code`)
// ============================================================================

Project fabt {
  database_type: 'PostgreSQL'
  Note: '''
    Finding A Bed Tonight — multi-tenant emergency shelter bed-availability
    platform. Schema uses tenant_id for row-level isolation, PostgreSQL RLS
    for DV-shelter data protection, and composite keys where domain semantics
    require it. All UUID primary keys are generated server-side (gen_random_uuid).

    v0.55 introduces an opt-in PII collection capability on the `reservation`
    table — three nullable `_encrypted` columns (held_for_client_name,
    held_for_client_dob, hold_notes) encrypted at rest with a per-tenant DEK
    (`tenant_dek.purpose='RESERVATION_PII'`, V93). Two-layer crypto-shred
    posture: (a) at-rest via tenant_dek rotation/hard-delete, (b) Spring
    Batch nulls the columns no later than 25 hours after a reservation
    reaches a terminal status (per `reentry-release-readiness` D10 + D11).
    These PII fields are server-side only and are NEVER published over
    AsyncAPI. The DV referral path is structurally segregated: V91's
    `shelter_dv_implies_dv_type` CHECK constraint enforces that any shelter
    with `dv_shelter=true` must carry `shelter_type='DV'`, routing DV
    inventory exclusively through the opaque-token DV referral path.
  '''
}

// ---------------------------------------------------------------------------
// Enums (curated from Java domain — sql2dbml does not generate enums from
// VARCHAR-with-CHECK columns)
// ---------------------------------------------------------------------------

Enum PopulationType {
  SINGLE_ADULT
  FAMILY_WITH_CHILDREN
  WOMEN_ONLY
  VETERAN
  YOUTH_18_24
  YOUTH_UNDER_18
  DV_SURVIVOR
}

Enum Role {
  COC_ADMIN
  COORDINATOR
  OUTREACH_WORKER
  PLATFORM_OPERATOR  // G-4.4 — replaced PLATFORM_ADMIN for platform-scoped operations
  PLATFORM_ADMIN     // Deprecated post-G-4.4; retained for migration compatibility
}

Enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  FAILING
  DEACTIVATED
  EXPIRED
}

Enum ShelterType {
  EMERGENCY
  DV
  TRANSITIONAL
  SUBSTANCE_USE_TREATMENT
  MENTAL_HEALTH_TREATMENT
  REENTRY_TRANSITIONAL  // V91 — transitional-reentry-support
  PERMANENT_SUPPORTIVE
}

Enum KeyPurpose {
  JWT_SIGN
  TOTP
  WEBHOOK_SECRET
  OAUTH2_CLIENT_SECRET
  HMIS_API_KEY
  RESERVATION_PII  // V93 — per-tenant DEK for held_for_client_* + hold_notes encryption
}

// ---------------------------------------------------------------------------
// Tables (regenerated 2026-04-30 from live schema via sql2dbml)
// 40 tables, 54 foreign-key refs at bottom. Column-level `note:` annotations
// reflect PostgreSQL `COMMENT ON COLUMN` statements where present in the
// migration files.
// ---------------------------------------------------------------------------

Table "api_key" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "tenant_id" uuid [not null]
  "shelter_id" uuid
  "key_hash" "character varying(255)" [not null]
  "key_suffix" character(4) [not null]
  "label" "character varying(255)"
  "role" "character varying(50)" [not null]
  "active" boolean [not null, default: true]
  "created_at" timestamp [not null, default: `now()`]
  "last_used_at" timestamp
  "old_key_hash" "character varying(255)"
  "old_key_expires_at" timestamp

  Indexes {
    key_hash [type: btree, name: "idx_api_key_hash"]
    old_key_hash [type: btree, name: "idx_api_key_old_hash"]
    tenant_id [type: btree, name: "idx_api_key_tenant_id"]
  }
}

Table "app_user" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "tenant_id" uuid [not null]
  "email" "character varying(255)" [not null]
  "password_hash" "character varying(255)"
  "display_name" "character varying(255)" [not null]
  "roles" "text[]" [not null, default: `'{}'::text[]`]
  "dv_access" boolean [not null, default: false]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "password_changed_at" timestamp
  "status" "character varying(20)" [not null, default: `'ACTIVE'::charactervarying`]
  "token_version" integer [not null, default: 0]
  "totp_secret_encrypted" "character varying(255)"
  "totp_enabled" boolean [not null, default: false]
  "recovery_codes" text

  Indexes {
    (tenant_id, email) [unique, name: "app_user_tenant_id_email_key"]
    tenant_id [type: btree, name: "idx_app_user_tenant_id"]
  }
}

Table "audit_events" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "timestamp" timestamp [not null, default: `clock_timestamp()`]
  "actor_user_id" uuid
  "target_user_id" uuid
  "action" "character varying(50)" [not null]
  "details" jsonb
  "ip_address" "character varying(45)"
  "tenant_id" uuid [note: 'Tenant isolation (cross-tenant-isolation-audit Phase 2.12). Set by AuditEventService.onAuditEvent from TenantContext on INSERT. Queries filter on tenant_id via AuditEventRepository.findByTargetUserIdAndTenantId.']
  "prev_hash" bytea [note: '''Phase G-1 hash chain: 32-byte SHA-256 of the immediately-preceding row in this tenant\'s chain (pulled from tenant_audit_chain_head.last_hash at INSERT time). First row in a tenant\'s chain picks up the 32-byte zero sentinel. NULL for pre-V85 historical rows and for orphan audits under SYSTEM_TENANT_ID.''']
  "row_hash" bytea [note: 'Phase G-1 hash chain: 32-byte SHA-256(prev_hash || canonical_json(row)) stored on the row itself. Verifier (G-2) re-computes on read and alerts on drift. NULL for pre-V85 historical rows and for orphan audits under SYSTEM_TENANT_ID.']


  Indexes {
    target_user_id [type: btree, name: "idx_audit_events_target_user"]
    (tenant_id, target_user_id, timestamp) [type: btree, name: "idx_audit_events_tenant_target"]
    timestamp [type: brin, name: "idx_audit_events_timestamp"]
  }
}

