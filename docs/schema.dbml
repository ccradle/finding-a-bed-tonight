// ============================================================================
// Finding A Bed Tonight (FABT) — Database Schema
// Source: Flyway migrations V1–V32 + V8.1
// Last synced: 2026-04-01
// ============================================================================

Project fabt {
  database_type: 'PostgreSQL'
  Note: '''
    Finding A Bed Tonight — multi-tenant emergency shelter bed-availability
    platform. Schema uses tenant_id for row-level isolation, PostgreSQL RLS
    for DV-shelter data protection, and composite keys where domain semantics
    require it. All UUID primary keys are generated server-side (gen_random_uuid).
  '''
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

Enum PopulationType {
  SINGLE_ADULT
  FAMILY_WITH_CHILDREN
  WOMEN_ONLY
  VETERAN
  YOUTH_18_24
  YOUTH_UNDER_18
  DV_SURVIVOR
}

Enum Role {
  PLATFORM_ADMIN
  COC_ADMIN
  COORDINATOR
  OUTREACH_WORKER
}

Enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  FAILING
  DEACTIVATED
  EXPIRED
}

// ---------------------------------------------------------------------------
// V1 — Tenant
// ---------------------------------------------------------------------------

Table tenant {
  id          uuid        [pk, note: 'gen_random_uuid()']
  name        varchar     [not null]
  slug        varchar     [unique, not null, note: 'URL-safe identifier for the CoC/tenant']
  config      jsonb       [note: '''Tenant-specific configuration. JSONB schema:
    hold_duration_minutes: int (default 90)
    api_key_auth_enabled: bool (default true)
    default_locale: string (default "en")
    observability.prometheus_enabled: bool (default true)
    observability.tracing_enabled: bool (default false)
    observability.tracing_endpoint: string (default "http://localhost:4318/v1/traces")
    observability.monitor_stale_interval_minutes: int (default 5)
    observability.monitor_dv_canary_interval_minutes: int (default 15)
    observability.monitor_temperature_interval_minutes: int (default 60)
    observability.temperature_threshold_f: double (default 32.0)
  ''']
  created_at  timestamptz [not null, default: `now()`]
  updated_at  timestamptz [not null, default: `now()`]
}

// ---------------------------------------------------------------------------
// V2 — App User
// ---------------------------------------------------------------------------

Table app_user {
  id            uuid        [pk, note: 'gen_random_uuid()']
  tenant_id     uuid        [not null, ref: > tenant.id]
  email         varchar     [not null]
  password_hash varchar     [not null]
  display_name  varchar     [not null]
  roles         "text[]"    [not null, note: 'Array of Role enum values']
  dv_access     boolean     [not null, default: false, note: 'Allowed to see DV-shelter data']
  status        varchar(20) [not null, default: 'ACTIVE', note: 'ACTIVE or DEACTIVATED']
  token_version integer     [not null, default: 0, note: 'Incremented on role/dvAccess/status change to invalidate JWTs']
  password_changed_at timestamptz [note: 'V27 — set on password change, JWTs issued before this are rejected']
  totp_secret_encrypted varchar(255) [note: 'V31 — AES-256-GCM encrypted TOTP base32 secret. Never stored plaintext.']
  totp_enabled  boolean     [not null, default: false, note: 'V31 — whether 2FA is active for this user']
  recovery_codes text       [note: 'V31 — JSON array of bcrypt-hashed single-use backup codes']
  created_at    timestamptz [not null, default: `now()`]
  updated_at    timestamptz [not null, default: `now()`]

  indexes {
    (tenant_id, email) [unique, name: 'uq_app_user_tenant_email']
  }
}

// One-time access codes for password recovery (V32)
// Admin-generated, 15-min expiry, single-use. Primary recovery path for field workers.
Table one_time_access_code {
  id          uuid        [pk, note: 'gen_random_uuid()']
  user_id     uuid        [not null, ref: > app_user.id, note: 'ON DELETE CASCADE']
  tenant_id   uuid        [not null, ref: > tenant.id]
  code_hash   varchar(255) [not null, note: 'BCrypt-hashed access code']
  expires_at  timestamptz [not null, note: '15-minute expiry from creation']
  used        boolean     [not null, default: false, note: 'Single-use — marked true after successful login']
  created_at  timestamptz [not null, default: `now()`]
  created_by  uuid        [not null, ref: > app_user.id, note: 'Admin who generated the code']

  indexes {
    (user_id) [name: 'idx_ott_user_id']
    (expires_at) [name: 'idx_ott_expires']
  }
}

// ---------------------------------------------------------------------------
// V29 — Audit Events
// ---------------------------------------------------------------------------

Table audit_events {
  id              uuid        [pk, note: 'gen_random_uuid()']
  timestamp       timestamptz [not null, default: `clock_timestamp()`]
  actor_user_id   uuid        [not null]
  target_user_id  uuid
  action          varchar(50) [not null, note: 'ROLE_CHANGED, USER_DEACTIVATED, USER_REACTIVATED, DV_ACCESS_CHANGED, PASSWORD_RESET']
  details         jsonb       [note: 'Old/new values, context']
  ip_address      varchar(45) [note: 'IPv4 or IPv6']

  indexes {
    timestamp [type: brin, name: 'idx_audit_events_timestamp']
    target_user_id [name: 'idx_audit_events_target_user']
  }

  note: 'Append-only audit trail. Retained indefinitely.'
}

// ---------------------------------------------------------------------------
// V3 — API Key
// ---------------------------------------------------------------------------

Table api_key {
  id               uuid        [pk, note: 'gen_random_uuid()']
  tenant_id        uuid        [not null, ref: > tenant.id]
  shelter_id       uuid        [ref: > shelter.id, note: 'Nullable — scoped to a single shelter when present']
  key_hash         varchar     [not null, note: 'SHA-256 hex of the full API key']
  key_suffix       "char(4)"   [not null, note: 'Last 4 chars for identification in UI']
  label            varchar     [not null, note: 'Human-readable label for the key']
  role             varchar     [not null, note: 'Role enum value governing permissions']
  active           boolean     [not null, default: true]
  created_at       timestamptz [not null, default: `now()`]
  last_used_at     timestamptz [note: 'Nullable — set on first use']
  old_key_hash     varchar     [note: 'V33 — SHA-256 of previous key during rotation grace period']
  old_key_expires_at timestamptz [note: 'V33 — grace period expiry (default +24h from rotation)']
}

// ---------------------------------------------------------------------------
// V4 — Shelter
// ---------------------------------------------------------------------------

Table shelter {
  id              uuid        [pk, note: 'gen_random_uuid()']
  tenant_id       uuid        [not null, ref: > tenant.id]
  name            varchar     [not null]
  address_street  varchar     [not null]
  address_city    varchar     [not null]
  address_state   varchar     [not null]
  address_zip     varchar     [not null]
  phone           varchar
  latitude        "double precision" [note: 'WGS 84 latitude']
  longitude       "double precision" [note: 'WGS 84 longitude']
  dv_shelter      boolean     [not null, default: false, note: 'Protected by PostgreSQL RLS']
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]

  indexes {
    (tenant_id, dv_shelter) [name: 'idx_shelter_tenant_dv']
    (tenant_id, name) [name: 'idx_shelter_tenant_name']
  }
}

// ---------------------------------------------------------------------------
// V5 — Shelter Constraints
// ---------------------------------------------------------------------------

Table shelter_constraints {
  shelter_id              uuid        [pk, ref: - shelter.id, note: 'ON DELETE CASCADE — 1:1 with shelter']
  sobriety_required       boolean     [not null, default: false]
  id_required             boolean     [not null, default: false]
  referral_required       boolean     [not null, default: false]
  pets_allowed            boolean     [not null, default: false]
  wheelchair_accessible   boolean     [not null, default: false]
  curfew_time             time        [note: 'Nullable — no curfew if null']
  max_stay_days           integer     [note: 'Nullable — no limit if null']
  population_types_served "text[]"    [note: 'Array of PopulationType enum values']
}

// ---------------------------------------------------------------------------
// V6/V20 — Shelter Capacity (DROPPED in V20)
// ---------------------------------------------------------------------------
// shelter_capacity table was dropped in V20. beds_total is now single-sourced
// from bed_availability snapshots. See bed_availability table below.

// ---------------------------------------------------------------------------
// V7 — Coordinator Assignment
// ---------------------------------------------------------------------------

Table coordinator_assignment {
  user_id    uuid [ref: > app_user.id, note: 'ON DELETE CASCADE']
  shelter_id uuid [ref: > shelter.id, note: 'ON DELETE CASCADE']

  indexes {
    (user_id, shelter_id) [pk, name: 'pk_coordinator_assignment']
  }
}

// ---------------------------------------------------------------------------
// V8.1 — (Reservation-related migration placeholder — no new table)
// ---------------------------------------------------------------------------
// V8.1 applies reservation soft-hold adjustments handled within existing
// domain logic. No additional DDL tables introduced.

// ---------------------------------------------------------------------------
// V9 — Import Log
// ---------------------------------------------------------------------------

Table import_log {
  id            uuid        [pk, note: 'gen_random_uuid()']
  tenant_id     uuid        [not null, ref: > tenant.id]
  import_type   varchar     [not null, note: 'e.g. HSDS, CSV, 211']
  filename      varchar     [not null]
  created_count integer     [not null, default: 0]
  updated_count integer     [not null, default: 0]
  skipped_count integer     [not null, default: 0]
  error_count   integer     [not null, default: 0]
  errors        jsonb       [note: 'Structured error details — row-level failures']
  created_at    timestamptz [not null, default: `now()`]
}

// ---------------------------------------------------------------------------
// V10 — Tenant OAuth2 Provider
// ---------------------------------------------------------------------------

Table tenant_oauth2_provider {
  id                      uuid        [pk, note: 'gen_random_uuid()']
  tenant_id               uuid        [not null, ref: > tenant.id]
  provider_name           varchar     [not null, note: 'e.g. google, okta, azure-ad']
  client_id               varchar     [not null]
  client_secret_encrypted varchar     [not null, note: 'AES-256-GCM encrypted at rest']
  issuer_uri              varchar     [not null]
  enabled                 boolean     [not null, default: true]
  created_at              timestamptz [not null, default: `now()`]

  indexes {
    (tenant_id, provider_name) [unique, name: 'uq_tenant_oauth2_provider']
  }
}

// ---------------------------------------------------------------------------
// V10 — User OAuth2 Link
// ---------------------------------------------------------------------------

Table user_oauth2_link {
  id                  uuid        [pk, note: 'gen_random_uuid()']
  user_id             uuid        [not null, ref: > app_user.id, note: 'ON DELETE CASCADE']
  provider_name       varchar     [not null]
  external_subject_id varchar     [not null, note: 'The sub claim from the IdP']
  linked_at           timestamptz [not null, default: `now()`]

  indexes {
    (provider_name, external_subject_id) [unique, name: 'uq_user_oauth2_link_provider_subject']
  }
}

// ---------------------------------------------------------------------------
// V11 — Subscription (Webhook)
// ---------------------------------------------------------------------------

Table subscription {
  id                   uuid              [pk, note: 'gen_random_uuid()']
  tenant_id            uuid              [not null, ref: > tenant.id]
  event_type           varchar           [not null, note: 'e.g. availability.updated, surge.activated']
  filter               jsonb             [note: 'Optional filter criteria — shelter_id, population_type, etc.']
  callback_url         varchar           [not null, note: 'HTTPS endpoint receiving webhook POSTs']
  callback_secret_hash varchar           [not null, note: 'AES-256-GCM encrypted secret for HMAC-SHA256 payload signing']
  status               varchar           [not null, default: 'ACTIVE', note: 'ACTIVE|PAUSED|FAILING|DEACTIVATED|CANCELLED']
  consecutive_failures integer           [not null, default: 0, note: 'V34 — auto-disable at 5; reset on success or re-enable']
  expires_at           timestamptz       [note: 'Nullable — no expiry if null']
  last_error           text              [note: 'Most recent delivery error message']
  created_at           timestamptz       [not null, default: `now()`]
}

// ---------------------------------------------------------------------------
// V34 — Webhook Delivery Log
// ---------------------------------------------------------------------------

Table webhook_delivery_log {
  id              uuid        [pk, note: 'gen_random_uuid()']
  subscription_id uuid        [not null, ref: > subscription.id, note: 'ON DELETE CASCADE']
  event_type      varchar     [not null]
  status_code     integer     [note: 'HTTP response status code (null if connection failed)']
  response_time_ms integer    [note: 'Round-trip time in milliseconds']
  attempted_at    timestamptz [not null, default: `now()`]
  attempt_number  integer     [not null, default: 1]
  response_body   text        [note: 'Truncated to 1KB, secrets redacted by WebhookResponseRedactor']
}

// ---------------------------------------------------------------------------
// V12 — Bed Availability (append-only snapshots)
// ---------------------------------------------------------------------------

// Single source of truth for beds_total (D10 — shelter_capacity dropped in V20).
// beds_total in this table is THE capacity. All capacity reads/writes go through here.
Table bed_availability {
  id                   uuid        [pk, note: 'gen_random_uuid()']
  shelter_id           uuid        [not null, ref: > shelter.id, note: 'ON DELETE CASCADE']
  tenant_id            uuid        [not null, ref: > tenant.id]
  population_type      varchar(50) [not null, note: 'PopulationType enum value']
  beds_total           integer     [not null, note: 'CHECK >= 0']
  beds_occupied        integer     [not null, default: 0, note: 'CHECK >= 0']
  beds_on_hold         integer     [not null, default: 0, note: 'CHECK >= 0']
  overflow_beds        integer     [not null, default: 0, note: 'V18 — surge overflow capacity beyond beds_total']
  accepting_new_guests boolean     [not null, default: true]
  snapshot_ts          timestamptz [not null, default: `now()`, note: 'When coordinator confirmed this data']
  updated_by           varchar(255) [note: 'User ID or identity of the updater']
  notes                varchar(500) [note: 'Free-text note from coordinator']

  indexes {
    (shelter_id, population_type, snapshot_ts) [unique, name: 'uq_bed_avail_shelter_pop_ts', note: 'ON CONFLICT DO NOTHING for concurrent inserts']
    (shelter_id, population_type, snapshot_ts) [name: 'idx_bed_avail_latest', note: 'DESC on snapshot_ts — supports DISTINCT ON latest-snapshot queries']
    (tenant_id, snapshot_ts) [name: 'idx_bed_avail_tenant', note: 'DESC on snapshot_ts']
    (tenant_id, shelter_id, population_type, snapshot_ts) [name: 'idx_bed_avail_tenant_latest', note: 'V25 — composite index for tenant-scoped latest-snapshot queries']
  }

  Note: '''
    Append-only table — rows are never UPDATEd or DELETEd by the application.
    Each row is a point-in-time snapshot of bed occupancy for one shelter +
    population type. beds_available is derived at query time:
    beds_total - beds_occupied - beds_on_hold (never stored).

    Concurrent insert safety: the UNIQUE constraint on (shelter_id,
    population_type, snapshot_ts) combined with ON CONFLICT DO NOTHING
    silently drops duplicate inserts when two coordinators submit at the
    exact same millisecond for the same shelter/population type.

    Protected by PostgreSQL RLS (V13): inherits DV-shelter visibility
    through a join to the shelter table's RLS policy.
  '''
}

// ---------------------------------------------------------------------------
// V13 — RLS for bed_availability
// ---------------------------------------------------------------------------
// RLS FORCE enabled on bed_availability. Policy dv_bed_availability_access
// uses EXISTS subquery through shelter table, inheriting the DV-shelter
// access control from V8/V8.1.

// ---------------------------------------------------------------------------
// V14 — Reservation (soft-hold bed placement)
// ---------------------------------------------------------------------------

Enum ReservationStatus {
  HELD
  CONFIRMED
  CANCELLED
  EXPIRED
}

Table reservation {
  id              uuid        [pk, note: 'gen_random_uuid()']
  shelter_id      uuid        [not null, ref: > shelter.id, note: 'ON DELETE CASCADE']
  tenant_id       uuid        [not null, ref: > tenant.id]
  population_type varchar(50) [not null, note: 'PopulationType enum value']
  user_id         uuid        [not null, ref: > app_user.id]
  status          varchar(20) [not null, default: 'HELD', note: 'ReservationStatus enum: HELD, CONFIRMED, CANCELLED, EXPIRED']
  expires_at      timestamptz [not null, note: 'Auto-expiry time (created_at + tenant hold_duration_minutes)']
  confirmed_at    timestamptz [note: 'Set when status transitions to CONFIRMED']
  cancelled_at    timestamptz [note: 'Set when status transitions to CANCELLED or EXPIRED']
  created_at      timestamptz [not null, default: `now()`]
  notes           varchar(500) [note: 'Free-text note from outreach worker']
  idempotency_key varchar(36)  [note: 'UUID for offline queue replay dedup — nullable, requests without key behave as before (V30)']

  indexes {
    (tenant_id, user_id, status) [name: 'idx_reservation_user_status']
    (shelter_id, population_type, status) [name: 'idx_reservation_shelter_status']
    (status, expires_at) [name: 'idx_reservation_expiry', note: 'Partial index WHERE status = HELD — expiry polling']
  }

  Note: '''
    Soft-hold bed reservation. Lifecycle: HELD → CONFIRMED | CANCELLED | EXPIRED.
    Terminal states are immutable. Creating a hold increments beds_on_hold via a
    new availability snapshot. Confirming converts to beds_occupied. Cancelling or
    expiring decrements beds_on_hold. Hold duration is configurable per tenant
    (default 90 minutes) via tenant.config JSONB field hold_duration_minutes.

    Auto-expiry: Lite tier uses @Scheduled polling (30s interval). Standard/Full
    tiers use Redis TTL with keyspace notification for near-instant expiry.

    Protected by PostgreSQL RLS (V15): inherits DV-shelter visibility through
    a join to the shelter table's RLS policy.
  '''
}

// ---------------------------------------------------------------------------
// V15 — RLS for reservation
// ---------------------------------------------------------------------------
// RLS FORCE enabled on reservation. Policy dv_reservation_access uses EXISTS
// subquery through shelter table, inheriting DV-shelter access control.

// ---------------------------------------------------------------------------
// V16 — Restricted application role (fabt_app)
// ---------------------------------------------------------------------------
// Creates fabt_app role with NOSUPERUSER, DML-only permissions.
// Application connects as fabt_app for RLS enforcement.
// Flyway DDL runs as fabt (owner).

// ---------------------------------------------------------------------------
// V17 — Surge Event (White Flag / emergency activation)
// ---------------------------------------------------------------------------

Enum SurgeEventStatus {
  ACTIVE
  DEACTIVATED
  EXPIRED
}

Table surge_event {
  id              uuid        [pk, note: 'gen_random_uuid()']
  tenant_id       uuid        [not null, ref: > tenant.id]
  status          varchar(20) [not null, default: 'ACTIVE', note: 'SurgeEventStatus enum']
  reason          varchar(500) [not null, note: 'Human-readable reason (e.g., White Flag)']
  bounding_box    jsonb       [note: 'Optional geographic scope — null = entire CoC']
  activated_by    uuid        [not null, ref: > app_user.id]
  activated_at    timestamptz [not null, default: `now()`]
  deactivated_at  timestamptz
  deactivated_by  uuid        [ref: > app_user.id]
  scheduled_end   timestamptz [note: 'Optional auto-expiry time']
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    (tenant_id, status) [name: 'idx_surge_event_tenant_status']
  }

  Note: '''
    First-class domain entity for emergency surge events (White Flag nights,
    disaster response, seasonal overflow). Lifecycle: ACTIVE → DEACTIVATED
    (manual) or EXPIRED (scheduled_end passed). One active surge per tenant.
    surge.activated and surge.deactivated events published to EventBus.
  '''
}

// ---------------------------------------------------------------------------
// V18 — Overflow beds on bed_availability
// ---------------------------------------------------------------------------
// ALTER TABLE bed_availability ADD COLUMN overflow_beds INTEGER DEFAULT 0
// Temporary capacity (cots, mats) reported by coordinators during active surges.

// ---------------------------------------------------------------------------
// V19 — RLS for surge_event
// ---------------------------------------------------------------------------
// RLS FORCE enabled on surge_event with tenant-scoped access policy.

// ---------------------------------------------------------------------------
// V20 — Drop shelter_capacity (see bed_availability note above)
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// V21 — DV Opaque Referral Token
// ---------------------------------------------------------------------------
// Privacy-preserving referral for DV shelters. Zero client PII.
// Terminal tokens hard-deleted within 24 hours by ReferralTokenPurgeService.

Table referral_token {
  id                  uuid        [pk, note: 'gen_random_uuid()']
  shelter_id          uuid        [not null, ref: > shelter.id, note: 'ON DELETE CASCADE']
  tenant_id           uuid        [not null, ref: > tenant.id]
  referring_user_id   uuid        [not null, ref: > app_user.id]
  household_size      integer     [not null, default: 1, note: 'CHECK BETWEEN 1 AND 20']
  population_type     varchar     [not null, note: 'PopulationType enum']
  urgency             varchar     [not null, note: 'STANDARD, URGENT, EMERGENCY']
  special_needs       varchar     [note: 'Free text — no client PII']
  callback_number     varchar     [not null, note: 'Referring worker phone, NOT client phone']
  status              varchar     [not null, note: 'PENDING, ACCEPTED, REJECTED, EXPIRED']
  created_at          timestamptz [not null]
  responded_at        timestamptz
  responded_by        uuid        [ref: > app_user.id]
  expires_at          timestamptz [not null]
  rejection_reason    varchar     [note: 'No client PII advisory']

  indexes {
    (shelter_id, status) [name: 'idx_referral_token_shelter_status']
    (referring_user_id, status) [name: 'idx_referral_token_user']
  }

  note: '''
  VAWA-compliant opaque referral. Contains zero client PII.
  Hard-deleted within 24 hours of terminal status.
  RLS inherits DV shelter access via shelter FK.
  '''
}

// ---------------------------------------------------------------------------
// V22 — HMIS Bridge (outbox + audit)
// ---------------------------------------------------------------------------
// Async push of bed inventory to HMIS vendors. No client PII.
// Outbox pattern: PENDING → SENT/FAILED → DEAD_LETTER after 3 retries.

Table hmis_outbox {
  id              uuid        [pk, note: 'gen_random_uuid()']
  tenant_id       uuid        [not null, ref: > tenant.id]
  shelter_id      uuid        [ref: > shelter.id, note: 'ON DELETE SET NULL']
  vendor_type     varchar     [not null, note: 'CLARITY, WELLSKY, CLIENTTRACK']
  status          varchar     [not null, note: 'PENDING, SENT, FAILED, DEAD_LETTER']
  payload         text        [not null, note: 'JSON or CSV payload']
  created_at      timestamptz [not null]
  sent_at         timestamptz
  error_message   varchar
  retry_count     integer     [not null, default: 0]

  indexes {
    (status, created_at) [name: 'idx_hmis_outbox_status']
    (tenant_id, status) [name: 'idx_hmis_outbox_tenant']
  }
}

Table hmis_audit_log {
  id              uuid        [pk, note: 'gen_random_uuid()']
  tenant_id       uuid        [not null, ref: > tenant.id]
  vendor_type     varchar     [not null]
  push_timestamp  timestamptz [not null]
  record_count    integer     [not null]
  status          varchar     [not null, note: 'SUCCESS, FAILED']
  error_message   varchar
  payload_hash    varchar     [note: 'SHA-256 of payload']

  indexes {
    (tenant_id, push_timestamp) [name: 'idx_hmis_audit_tenant_ts']
  }

  note: '''
  Append-only audit log of HMIS data transmissions.
  Required by HMIS security standards.
  '''
}

// ---------------------------------------------------------------------------
// V23 — CoC Analytics (bed search log + daily utilization summary + BRIN)
// ---------------------------------------------------------------------------
// Bed search demand logging captures every search including zero-result searches
// — the strongest unmet demand signal. Pre-aggregated daily summary avoids
// querying raw snapshots (1,460+ rows/shelter/year → 365 rows/shelter/year).
// BRIN index on bed_availability.snapshot_ts for efficient analytics range queries.

Table bed_search_log {
  id              uuid        [pk, note: 'gen_random_uuid()']
  tenant_id       uuid        [not null, ref: > tenant.id]
  population_type varchar     [note: 'PopulationType enum, nullable (unfiltered search)']
  results_count   integer     [not null]
  search_ts       timestamptz [not null, default: `now()`]

  indexes {
    (tenant_id, search_ts) [name: 'idx_bed_search_log_tenant_ts']
  }

  note: '''
  Every bed search is logged here — especially zero-result searches.
  Zero-result search count is the strongest unmet demand signal:
  "47 searches for SINGLE_ADULT beds with zero results last Tuesday night."
  Used for HUD grant applications and operational planning.
  '''
}

Table daily_utilization_summary {
  id               uuid             [pk, note: 'gen_random_uuid()']
  tenant_id        uuid             [not null, ref: > tenant.id]
  shelter_id       uuid             [not null, ref: > shelter.id, note: 'ON DELETE CASCADE']
  population_type  varchar          [not null, note: 'PopulationType enum']
  summary_date     date             [not null]
  avg_utilization  "double precision" [not null]
  max_occupied     integer          [not null]
  min_available    integer          [not null]
  snapshot_count   integer          [not null]

  indexes {
    (tenant_id, shelter_id, population_type, summary_date) [unique, name: 'uq_daily_util_tenant_shelter_pop_date']
  }

  note: '''
  Pre-aggregated utilization summary populated by Spring Batch daily
  aggregation job (3 AM). Analytics dashboard queries hit this table
  instead of raw bed_availability snapshots.
  One row per (tenant, shelter, population_type, date).
  '''
}

// ---------------------------------------------------------------------------
// V23 — BRIN index on bed_availability.snapshot_ts
// ---------------------------------------------------------------------------
// idx_bed_avail_snapshot_brin: BRIN index on bed_availability(snapshot_ts)
// with pages_per_range=128. Ideal for append-only table where physical row
// order correlates with timestamp. ~0.1% the size of a B-tree, near-zero
// insert cost. Existing B-tree indexes remain for OLTP.

// ---------------------------------------------------------------------------
// V24 — Spring Batch schema
// ---------------------------------------------------------------------------
// Spring Batch 5.1.x execution metadata tables. Managed by Flyway
// (spring.batch.jdbc.initialize-schema=never). Stores job/step execution
// history for: daily aggregation, HMIS push, HIC/PIT export.

Table batch_job_instance {
  job_instance_id bigint      [pk]
  version         bigint
  job_name        varchar(100) [not null]
  job_key         varchar(32) [not null]

  indexes {
    (job_name, job_key) [unique, name: 'JOB_INST_UN']
  }
}

Table batch_job_execution {
  job_execution_id bigint      [pk]
  version          bigint
  job_instance_id  bigint      [not null, ref: > batch_job_instance.job_instance_id]
  create_time      timestamp   [not null]
  start_time       timestamp
  end_time         timestamp
  status           varchar(10)
  exit_code        varchar(2500)
  exit_message     varchar(2500)
  last_updated     timestamp
}

Table batch_job_execution_params {
  job_execution_id bigint      [not null, ref: > batch_job_execution.job_execution_id]
  parameter_name   varchar(100) [not null]
  parameter_type   varchar(100) [not null]
  parameter_value  varchar(2500)
  identifying      "char(1)"   [not null]
}

Table batch_step_execution {
  step_execution_id  bigint      [pk]
  version            bigint      [not null]
  step_name          varchar(100) [not null]
  job_execution_id   bigint      [not null, ref: > batch_job_execution.job_execution_id]
  create_time        timestamp   [not null]
  start_time         timestamp
  end_time           timestamp
  status             varchar(10)
  commit_count       bigint
  read_count         bigint
  filter_count       bigint
  write_count        bigint
  read_skip_count    bigint
  write_skip_count   bigint
  process_skip_count bigint
  rollback_count     bigint
  exit_code          varchar(2500)
  exit_message       varchar(2500)
  last_updated       timestamp
}

Table batch_step_execution_context {
  step_execution_id  bigint      [pk, ref: - batch_step_execution.step_execution_id]
  short_context      varchar(2500) [not null]
  serialized_context text
}

Table batch_job_execution_context {
  job_execution_id   bigint      [pk, ref: - batch_job_execution.job_execution_id]
  short_context      varchar(2500) [not null]
  serialized_context text
}
