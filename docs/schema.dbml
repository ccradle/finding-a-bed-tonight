  "created_count" integer [not null, default: 0]
  "updated_count" integer [not null, default: 0]
  "skipped_count" integer [not null, default: 0]
  "error_count" integer [not null, default: 0]
  "errors" jsonb
  "created_at" timestamp [not null, default: `now()`]

  Indexes {
    (tenant_id, created_at) [type: btree, name: "idx_import_log_tenant_created"]
  }
}

Table "jwt_revocations" {
  "kid" uuid [pk, not null]
  "expires_at" timestamp [not null, note: 'Mirrors the natural exp claim of the revoked JWT. After this timestamp the row is safe to GC because the JWT itself is already expired.']
  "revoked_at" timestamp [not null, default: `clock_timestamp()`]

  Indexes {
    expires_at [type: btree, name: "jwt_revocations_by_expires_at"]
  }
  Note: 'Fast-path blocklist for revoked JWT kids (suspend, generation bump). Checked early in validate. Pruned daily where expires_at < now().'
}

Table "kid_to_tenant_key" {
  "kid" uuid [pk, not null, note: 'Random UUID emitted in the JWT kid header. Carries no structural information about the tenant or generation it resolves to.']
  "tenant_id" uuid [not null]
  "generation" integer [not null]
  "created_at" timestamp [not null, default: `clock_timestamp()`]

  Indexes {
    (tenant_id, generation) [type: btree, name: "kid_to_tenant_key_by_tenant"]
    (tenant_id, generation) [type: btree, unique, name: "kid_to_tenant_key_unique_per_generation"]
  }
  Note: 'Server-side opaque-kid → (tenant, generation) registry per design D1. Populated on JWT sign, read on validate. Cached in-memory at the application layer.'
}

Table "notification" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "tenant_id" uuid [not null]
  "recipient_id" uuid [not null]
  "type" "character varying(50)" [not null]
  "severity" "character varying(20)" [not null, default: `'INFO'::charactervarying`]
  "payload" jsonb [not null, default: `'{}'::jsonb`]
  "read_at" timestamp
  "acted_at" timestamp
  "created_at" timestamp [not null, default: `now()`]
  "expires_at" timestamp

  Indexes {
    `((payload->>'referralId'::text))` [type: btree, name: "idx_notification_payload_referral_id"]
    (tenant_id, created_at) [type: btree, name: "idx_notification_tenant"]
    (recipient_id, created_at) [type: btree, name: "idx_notification_unread"]
  }
}

Table "one_time_access_code" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "user_id" uuid [not null]
  "tenant_id" uuid [not null]
  "code_hash" "character varying(255)" [not null]
  "expires_at" timestamp [not null]
  "used" boolean [not null, default: false]
  "created_at" timestamp [not null, default: `now()`]
  "created_by" uuid [not null]

  Indexes {
    (tenant_id, expires_at) [type: btree, name: "idx_one_time_access_code_tenant_expires"]
    expires_at [type: btree, name: "idx_ott_expires"]
    user_id [type: btree, name: "idx_ott_user_id"]
  }
}

Table "password_reset_token" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "user_id" uuid [not null]
  "tenant_id" uuid [not null]
  "token_hash" character(64) [not null]
  "expires_at" timestamp [not null]
  "used" boolean [not null, default: false]
  "created_at" timestamp [not null, default: `now()`]

  Indexes {
    expires_at [type: btree, name: "idx_password_reset_token_expires"]
    token_hash [type: btree, unique, name: "idx_password_reset_token_hash"]
    (tenant_id, expires_at) [type: btree, name: "idx_password_reset_token_tenant_expires"]
  }
}

Table "platform_admin_access_log" {
  "id" uuid [pk, not null]
  "platform_user_id" uuid [not null]
  "action" text [not null]
  "resource" text
  "resource_id" uuid
  "justification" text [not null]
  "request_method" text [not null]
  "request_path" text [not null]
  "request_body_excerpt" text [note: 'Body fingerprint (Content-Type + Content-Length + SHA-256), NEVER raw body. Forensic correlation against application logs at the same audit_event_id.']
  "before_state" jsonb
  "after_state" jsonb
  "audit_event_id" uuid [note: 'Pre-generated id of the companion audit_events row (Decision 11). No FK enforcement (D1) — Phase B forbids audit_events deletes so orphan risk is hypothetical.']
  "timestamp" timestamp [not null, default: `now()`]


  Indexes {
    (action, timestamp) [type: btree, name: "platform_admin_access_log_action_time"]
    resource_id [type: btree, name: "platform_admin_access_log_resource"]
    timestamp [type: btree, name: "platform_admin_access_log_time"]
    (platform_user_id, timestamp) [type: btree, name: "platform_admin_access_log_user_time"]
  }
  Note: 'Phase G-4.3 platform-admin audit ledger. Append-only via REVOKE UPDATE/DELETE + BEFORE-mutate trigger. Written by the @PlatformAdminOnly AOP aspect alongside an audit_events row in a single REQUIRES_NEW transaction. Compliance queries: see docs/runbook.md. WARNING: an audit row indicates the action was ATTEMPTED, not necessarily completed — for actual completion correlate via audit_event_id against application logs at the same correlation window.'
}

Table "platform_config" {
  "id" uuid [pk, not null, default: `'00000000-0000-0000-0000-000000000001'::uuid`, note: 'Singleton row id enforced by platform_config_singleton CHECK constraint.']
  "config" jsonb [not null, default: `'{}'::jsonb`, note: 'Platform-wide observability + scheduler config. Schema (informally enforced by PlatformConfig record + endpoint validation): prometheus_enabled (bool), tracing_enabled (bool), tracing_endpoint (string URL), monitor_stale_interval_minutes (int 1..1440), monitor_dv_canary_interval_minutes (int 1..1440), monitor_temperature_interval_minutes (int 1..1440). Bounds enforced by the controller, not at the DB layer (design D4).']
  "updated_at" timestamp [not null, default: `now()`]
  "updated_by" uuid [note: 'platform_user.id of the operator who last applied a change, or NULL for the initial-seed row. Cross-references the audit_events row for each PLATFORM_OBSERVABILITY_UPDATED emission.']

  Note: 'Platform-wide observability + scheduler config (V98, platform-observability-split, 2026-05). Single-row table enforced by the platform_config_singleton CHECK constraint. Read by PlatformConfigService at startup + on every monitor reschedule; written by PUT /api/v1/platform/observability (PLATFORM_OPERATOR + @PlatformAdminOnly + X-Platform-Justification header). Houses the 6 tenant-agnostic fields the /admin#observability tab used to (incorrectly) store per-tenant — temperature_threshold_f stays per-tenant via /admin#surge.'
}

Table "platform_key_material" {
  "id" uuid [pk, not null]
  "generation" integer [not null]
  "kid" text [unique, not null]
  "key_bytes" bytea [not null]
  "active" boolean [not null, default: true]
  "created_at" timestamp [not null, default: `now()`]

  Indexes {
    kid [type: btree, name: "platform_key_material_active_kid"]
    `(true)` [type: btree, unique, name: "platform_key_material_one_active"]
  }
  Note: 'JWT signing key for iss=fabt-platform tokens (Phase G-4 / issue #141). One active row at a time enforced by EXCLUDE constraint. Initial row populated by PlatformKeyRotationService on first boot via HKDF from master KEK.'
}

Table "platform_user" {
  "id" uuid [pk, not null]
  "email" text
  "password_hash" text
  "mfa_secret" text
  "mfa_enabled" boolean [not null, default: false]
  "account_locked" boolean [not null, default: true]
  "created_at" timestamp [not null, default: `now()`]
  "last_login_at" timestamp
  "anonymized_at" timestamp
  "failed_mfa_attempts_at" "timestamp[]" [not null, default: `'{}'::timestampwithtimezone[]`, note: 'Rolling window of recent failed-MFA timestamps. Pruned on every insert by platform_user_record_failure to the threshold-window only.']
  "locked_out_at" timestamp [note: 'NULL = not auto-locked. Non-NULL = MFA-counter triggered lockout at this instant. Cron clears + unlocks at +15min.']
  "last_totp_code" text [note: 'Most-recently-accepted TOTP code; used to reject replay within the 89s ±1-step RFC 6238 window.']
  "last_totp_used_at" timestamp
  "mfa_enrolled_at" timestamp

  Indexes {
    email [type: btree, unique, name: "platform_user_email_unique"]
    locked_out_at [type: btree, name: "platform_user_locked_out_at"]
  }
  Note: 'Platform operator identity (Phase G-4 / issue #141). Distinct from app_user — no tenant_id. JWTs issued from this table use iss=fabt-platform signed by platform_key_material.'
}

Table "platform_user_backup_code" {
  "id" uuid [pk, not null]
  "platform_user_id" uuid [not null]
  "code_hash" text [not null]
  "code_salt" bytea [not null]
  "used_at" timestamp
  "created_at" timestamp [not null, default: `now()`]

  Indexes {
    platform_user_id [type: btree, name: "platform_user_backup_code_owner"]
  }
  Note: 'Single-use SHA-256+salt-hashed MFA recovery codes for platform_user. 10 codes generated at MFA setup, displayed once, marked used_at on use. Regeneration via Phase H+ endpoint deletes and re-creates the row set.'
}

Table "referral_token" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "shelter_id" uuid [not null]
  "tenant_id" uuid [not null]
  "referring_user_id" uuid [not null]
  "household_size" integer [not null, default: 1]
  "population_type" "character varying(50)" [not null]
  "urgency" "character varying(20)" [not null, default: `'STANDARD'::charactervarying`]
  "special_needs" "character varying(500)"
  "callback_number" "character varying(50)" [not null]
  "status" "character varying(20)" [not null, default: `'PENDING'::charactervarying`]
  "created_at" timestamp [not null, default: `now()`]
  "responded_at" timestamp
  "responded_by" uuid
  "expires_at" timestamp [not null]
  "rejection_reason" "character varying(500)"
  "escalation_policy_id" uuid
  "claimed_by_admin_id" uuid
  "claim_expires_at" timestamp
  "escalation_chain_broken" boolean [not null, default: false]
  "shelter_name" "character varying(255)"


  Indexes {
    claim_expires_at [type: btree, name: "idx_referral_token_active_claim"]
    (status, expires_at) [type: btree, name: "idx_referral_token_expired"]
    (tenant_id, expires_at) [type: btree, name: "idx_referral_token_pending_by_expiry"]
    created_at [type: btree, name: "idx_referral_token_pending_created_at"]
    (status, expires_at) [type: btree, name: "idx_referral_token_pending_expires"]
    (status, responded_at) [type: btree, name: "idx_referral_token_purge"]
    (shelter_id, status) [type: btree, name: "idx_referral_token_shelter_status"]
    (referring_user_id, status) [type: btree, name: "idx_referral_token_user"]
    (referring_user_id, shelter_id) [type: btree, unique, name: "uq_referral_token_pending"]
  }
}

Table "reservation" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "shelter_id" uuid [not null]
  "tenant_id" uuid [not null]
  "population_type" "character varying(50)" [not null]
  "user_id" uuid [not null]
  "status" "character varying(50)" [not null, default: `'HELD'::charactervarying`]
  "expires_at" timestamp [not null]
  "confirmed_at" timestamp
  "cancelled_at" timestamp
  "created_at" timestamp [not null, default: `now()`]
  "notes" "character varying(500)"
  "idempotency_key" "character varying(36)"
  "held_for_client_name_encrypted" text [note: 'Base64 v1 EncryptionEnvelope of the third-party client name (when an outreach worker / navigator holds a bed on behalf of someone who is not a platform user). Encrypted via SecretEncryptionService.encryptForTenant(tenantId, KeyPurpose.RESERVATION_PII, name). Spring Batch purges 24h post-resolution per design D4.']
  "held_for_client_dob_encrypted" text [note: 'Base64 v1 EncryptionEnvelope of the third-party client date of birth (ISO-8601 string format before encryption). Used for shelter check-in confirmation. Same purge schedule as held_for_client_name_encrypted.']
  "hold_notes_encrypted" text [note: 'Base64 v1 EncryptionEnvelope of free-text coordination notes from navigator to shelter coordinator. May contain names and contact information of supervision officers. Same purge schedule as held_for_client_name_encrypted — NOT a permanent record.']


  Indexes {
    (status, expires_at) [type: btree, name: "idx_reservation_expiry"]
    (shelter_id, population_type, status) [type: btree, name: "idx_reservation_shelter_status"]
    (tenant_id, user_id, status) [type: btree, name: "idx_reservation_user_status"]
  }
}

Table "shelter" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "tenant_id" uuid [not null]
  "name" "character varying(255)" [not null]
  "address_street" "character varying(255)"
  "address_city" "character varying(100)"
  "address_state" "character varying(50)"
  "address_zip" "character varying(20)"
  "phone" "character varying(50)"
  "latitude" doubleprecision
  "longitude" doubleprecision
  "dv_shelter" boolean [not null, default: false]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "active" boolean [not null, default: true]
  "deactivated_at" timestamp
  "deactivated_by" uuid
  "deactivation_reason" "character varying(50)"
  "shelter_type" "character varying(50)" [not null, default: `'EMERGENCY'::charactervarying`, note: 'Controlled vocabulary classification (EMERGENCY/DV/TRANSITIONAL/SUBSTANCE_USE_TREATMENT/MENTAL_HEALTH_TREATMENT/REENTRY_TRANSITIONAL/PERMANENT_SUPPORTIVE/RAPID_REHOUSING). Enforced at app layer via ShelterType enum. Carries no implied compliance status — self-reported classification for filtering and display only.']
  "county" "character varying(100)" [note: 'Shelter county. Validated app-layer against tenant.config.active_counties (default: NC 100-county list). NO DB-level enum (design D3 / warroom H2 2026-04-28).']
  "requires_verification_call" boolean [not null, default: false, note: 'Sentinel flag: shelter requires a direct call before eligibility can be assumed, regardless of what eligibility_criteria says. Used by the search UI to render the "call to verify" badge AND by BedSearchService H1 three-way logic — when acceptsFelonies=true is queried and a shelter has null eligibility_criteria, the shelter is included only if requires_verification_call=true (annotated with the badge). See design D1 acceptsFelonies-with-sentinel section.']


  Indexes {
    (tenant_id, county) [type: btree, name: "idx_shelter_tenant_county"]
    (tenant_id, dv_shelter) [type: btree, name: "idx_shelter_tenant_dv"]
    (tenant_id, name) [type: btree, name: "idx_shelter_tenant_name"]
  }
}

Table "shelter_constraints" {
  "shelter_id" uuid [pk, not null]
  "sobriety_required" boolean [not null, default: false]
  "id_required" boolean [not null, default: false]
  "referral_required" boolean [not null, default: false]
  "pets_allowed" boolean [not null, default: false]
  "wheelchair_accessible" boolean [not null, default: false]
  "curfew_time" time
  "max_stay_days" integer
  "population_types_served" "text[]" [not null, default: `'{}'::text[]`]
  "eligibility_criteria" jsonb [note: 'Structured eligibility criteria per design D1. Schema includes criminal_record_policy (sub-object: accepts_felonies bool, excluded_offense_types string[], individualized_assessment bool, vawa_protections_apply bool, notes), program_requirements string[], documentation_required string[], intake_hours string, custom_tags string[]. All keys nullable. NULL means "not specified" — UI shows the requires_verification_call sentinel as fallback.']

  Indexes {
    eligibility_criteria [type: gin, name: "idx_shelter_constraints_eligibility"]
  }
}

Table "subscription" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "tenant_id" uuid [not null]
  "event_type" "character varying(100)" [not null]
  "filter" jsonb [not null, default: `'{}'::jsonb`]
  "callback_url" "character varying(1000)" [not null]
  "callback_secret_hash" "character varying(255)" [not null]
  "status" "character varying(50)" [not null, default: `'ACTIVE'::charactervarying`]
  "expires_at" timestamp
  "last_error" text
  "created_at" timestamp [not null, default: `now()`]
  "consecutive_failures" integer [not null, default: 0]

  Indexes {
    (event_type, status) [type: btree, name: "idx_subscription_event_type"]
    (tenant_id, status) [type: btree, name: "idx_subscription_tenant_status"]
  }
}

Table "surge_event" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "tenant_id" uuid [not null]
  "status" "character varying(20)" [not null, default: `'ACTIVE'::charactervarying`]
  "reason" "character varying(500)" [not null]
  "bounding_box" jsonb
  "activated_by" uuid [not null]
  "activated_at" timestamp [not null, default: `now()`]
  "deactivated_at" timestamp
  "deactivated_by" uuid
  "scheduled_end" timestamp
  "created_at" timestamp [not null, default: `now()`]


  Indexes {
    (tenant_id, status) [type: btree, name: "idx_surge_event_tenant_status"]
  }
}

Table "tenant" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`, note: 'Parent of CASCADE FKs (V84 + V61 + V80 + V82). hardDelete(tenant_id) chain-removes every per-tenant child row in a single DELETE. audit_events preserves its tenant_id without FK per shred-auditability contract (Q-F6-5).']
  "name" "character varying(255)" [not null]
  "slug" "character varying(100)" [unique, not null]
  "config" jsonb [not null, default: `'{}'::jsonb`, note: 'Tenant-scoped operational config. Known keys: hold_duration_minutes (slice 2C); features.reentryMode (v0.55); active_counties; dv_address_visibility; dv_policy_enabled (boolean, default false on absent — gates per-shelter dv_shelter=true writes via ShelterService invariant; backfilled true by V97 for tenants with existing DV shelters; flipped via dedicated PATCH /api/v1/admin/tenants/{id}/dv-policy endpoint per dv-policy-tenant-flag OpenSpec change 2026-05); contact.email (string, RFC 5322 email format, max 254 chars, default empty — per-tenant override of platform contact email surfaced via GET /api/v1/public/contact-info; flipped via dedicated PATCH /api/v1/admin/tenants/{id}/contact-email endpoint per info-email-contact OpenSpec change 2026-05; non-empty value FORBIDDEN when dv_policy_enabled=true to avoid DV-tenant inadvertently advertising a non-DV-safe inbox; empty-string PATCH always allowed to revert to platform inheritance).']
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "state" "character varying(32)" [not null, default: `'ACTIVE'::charactervarying`, note: 'Lifecycle FSM state. Phase A column-only; Phase F adds the transition state machine.']
  "jwt_key_generation" integer [not null, default: 1, note: 'Generation counter for per-tenant JWT signing key. Bumped on suspend (atomic invalidation) and operator rotation. Read by JwtService.validate when resolving kid → (tenant, generation).']
  "data_residency_region" "character varying(50)" [not null, default: `'us-any'::charactervarying`, note: 'Region pin (e.g. us-ashburn, eu-frankfurt). Standard pooled tier uses us-any. Read by Phase F silo routing.']
  "oncall_email" "character varying(255)" [note: 'Per-tenant on-call email for tenant-tagged Grafana alerts. Nullable; falls back to platform-default routing when absent.']
  "offboard_export_receipt_uri" text [note: 'Filesystem path (v0.51.0) or S3 URI (Phase H) where TenantOffboardExportService wrote the GDPR Art. 20 data-portability dump. Set by offboard(); required non-null before archive() proceeds.']
  "archived_at" timestamp [note: 'Timestamp when archive() flipped state to ARCHIVED. Starts the 30-day retention clock for hardDelete() (F-6).']

}

Table "tenant_audit_chain_head" {
  "tenant_id" uuid [pk, not null]
  "last_hash" bytea [not null]
  "last_row_id" uuid
  "updated_at" timestamp [not null, default: `now()`]

  Note: 'Per-tenant hash-chain pointer for tamper-evident audit (Phase F-4 seed, Phase G-1 writer). Single row per tenant — UPDATEd on every audit INSERT by the future AuditChainHasher component.'
}

Table "tenant_dek" {
  "kid" uuid [pk, not null, note: 'Opaque random UUID emitted in the v1 EncryptionEnvelope kid field. Disjoint pool from kid_to_tenant_key (which holds JWT-signing kids).']
  "tenant_id" uuid [not null]
  "purpose" "character varying(32)" [not null, note: 'Canonical purpose string matching org.fabt.shared.security.KeyPurpose. Purpose binding prevents a TOTP ciphertext from decrypting under the webhook-secret DEK even if both DEKs exist for the same tenant.']
  "generation" integer [not null, default: 1]
  "wrapped_dek" bytea [not null, note: 'AES-KWP output (40 bytes for a 32-byte DEK). Unwrap requires the master-KEK-derived wrapping key from KeyDerivationService.deriveKekWrappingKey(tenant_id). Without this row the DEK cannot be reconstructed — that is the whole point.']
  "active" boolean [not null, default: true, note: 'TRUE for the current generation per (tenant, purpose); partial unique index enforces at most one active row. Old generations linger during the rotation grace window so pre-rotation ciphertexts still decrypt.']
  "created_at" timestamp [not null, default: `clock_timestamp()`]
  "rotated_at" timestamp


  Indexes {
    (tenant_id, purpose) [type: btree, unique, name: "tenant_dek_active_per_tenant_purpose_uq"]
    tenant_id [type: btree, name: "tenant_dek_by_tenant"]
    (tenant_id, purpose, generation) [type: btree, unique, name: "tenant_dek_tenant_purpose_gen_uq"]
  }
  Note: 'Per-tenant, per-purpose random 256-bit DEKs wrapped via AES-KWP (RFC 5649) under a master-KEK-derived wrapping key. Shred surface per design-f6-real-cryptoshred §3: ON DELETE CASCADE from tenant means hardDelete destroys every wrapped DEK for the tenant in a single DB statement, rendering any surviving ciphertext permanently unrecoverable.'
}

Table "tenant_key_material" {
  "tenant_id" uuid [not null]
  "generation" integer [not null, note: 'Monotonic generation counter per tenant. Starts at 1, bumps on rotation. Combined with tenant_id, identifies a unique HKDF-derived DEK.']
  "created_at" timestamp [not null, default: `clock_timestamp()`]
  "rotated_at" timestamp
  "active" boolean [not null, default: true, note: 'TRUE for the current generation per tenant; partial unique index enforces at most one active row. Old generations linger for the grace window then can be GCd.']


  Indexes {
    (tenant_id, generation) [pk, name: "tenant_key_material_pkey"]
    tenant_id [type: btree, unique, name: "tenant_key_material_active_per_tenant"]
  }
  Note: 'Per-tenant DEK generation history. Exactly one active row per tenant; old generations preserved for dual-key-accept decryption during rotation grace.'
}

Table "tenant_oauth2_provider" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "tenant_id" uuid [not null]
  "provider_name" "character varying(100)" [not null]
  "client_id" "character varying(500)" [not null]
  "client_secret_encrypted" "character varying(1000)" [not null]
  "issuer_uri" "character varying(500)"
  "enabled" boolean [not null, default: true]
  "created_at" timestamp [not null, default: `now()`]

  Indexes {
    (tenant_id, provider_name) [unique, name: "tenant_oauth2_provider_tenant_id_provider_name_key"]
  }
}

Table "user_oauth2_link" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "user_id" uuid [not null]
  "provider_name" "character varying(100)" [not null]
  "external_subject_id" "character varying(500)" [not null]
  "linked_at" timestamp [not null, default: `now()`]

  Indexes {
    (provider_name, external_subject_id) [unique, name: "user_oauth2_link_provider_name_external_subject_id_key"]
    user_id [type: btree, name: "idx_user_oauth2_link_user"]
  }
}

Table "webhook_delivery_log" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "subscription_id" uuid [not null]
  "event_type" "character varying(100)" [not null]
  "status_code" integer
  "response_time_ms" integer
  "attempted_at" timestamp [not null, default: `now()`]
  "attempt_number" integer [not null, default: 1]
  "response_body" text

  Indexes {
    (subscription_id, attempted_at) [type: btree, name: "idx_delivery_log_subscription"]
  }
}

